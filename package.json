{
  "name": "xpto-mylineage-server",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build:topola": "esbuild topola-entry.js --bundle --outfile=topola-bundle.js --format=iife --global-name=TopolaLib --platform=browser --minify",
    "build:familychart": "esbuild family-chart-entry.js --bundle --outfile=family-chart-bundle.js --format=iife --global-name=F3Lib --platform=browser --minify",
    "build:qrcode": "esbuild qrcode-entry.js --bundle --outfile=qrcode-bundle.js --format=iife --platform=browser --minify",
    "build:livro": "esbuild livro-entry.js --bundle --outfile=livro-bundle.js --format=iife --global-name=PageFlipLib --platform=browser --minify",
    "build:all": "npm run build:topola && npm run build:familychart && npm run build:qrcode && npm run build:livro",
    "prestart": "npm run build:all",
    "test": "jest",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:all": "jest tests/unit tests/integration --verbose",
    "test:coverage": "jest --coverage",
    "migrate": "node migrations/run.js",
    "migrate:create": "node -e \"const n=process.argv[1]||'migration';const ts=Date.now();require('fs').writeFileSync('migrations/'+ts+'-'+n+'.js','module.exports={up:async(pool)=>{},down:async(pool)=>{}};\\n');console.log('Created migrations/'+ts+'-'+n+'.js');\""
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/unit/**/*.test.js",
      "<rootDir>/tests/integration/**/*.test.js"
    ],
    "testTimeout": 15000,
    "coverageDirectory": "tests/coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "server.js"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "family-chart": "^0.9.0",
    "page-flip": "^2.0.7",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "topola": "^3.8.3"
  },
  "devDependencies": {
    "d3": "^7.9.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
