{
  "name": "xpto-mylineage-server",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build:topola": "esbuild topola-entry.js --bundle --outfile=topola-bundle.js --format=iife --global-name=TopolaLib --platform=browser --minify",
    "build:familychart": "esbuild family-chart-entry.js --bundle --outfile=family-chart-bundle.js --format=iife --global-name=F3Lib --platform=browser --minify",
    "build:all": "npm run build:topola && npm run build:familychart",
    "prestart": "npm run build:all",
    "test": "jest",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:all": "jest tests/unit tests/integration --verbose",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/unit/**/*.test.js",
      "<rootDir>/tests/integration/**/*.test.js"
    ],
    "testTimeout": 15000,
    "coverageDirectory": "tests/coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "server.js"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "family-chart": "^0.9.0",
    "topola": "^3.8.3"
  },
  "devDependencies": {
    "d3": "^7.9.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
